generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String     @id @default(cuid())
  name             String?
  email            String?    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role       @default(USER)
  resetToken       String?
  resetTokenExpiry DateTime?
  accounts         Account[]
  sessions         Session[]
  comments         Comment[]
  bookmarks        Bookmark[]
  createdAt        DateTime   @default(now())
}

enum Role {
  USER
  ADMIN
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postSlug  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postSlug])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  postSlug  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postSlug])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  excerpt    String
  content    String   @db.Text
  coverImage String
  category   String
  tags       String[]
  author     String   @default("Aana")
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // SEO Fields
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  canonicalUrl    String?
  robots          String  @default("index")
  ogTitle         String?
  ogDescription   String?

  // Content Enhancement
  readingTime     Int?
  tableOfContents Boolean @default(true)
  contentType     String? // review, news, guide, opinion, comparison

  // Visibility
  featuredPost     Boolean @default(false)
  pinnedPost       Boolean @default(false)
  trending         Boolean @default(false)
  homepagePriority Int?
  showInCategory   Boolean @default(true)
  hideFromSearch   Boolean @default(false)

  // Monetization
  sponsoredPost       Boolean @default(false)
  sponsorName         String?
  affiliateDisclosure String?
  adsEnabled          Boolean @default(true)

  // Technical
  schemaType     String    @default("BlogPosting")
  commentEnabled Boolean   @default(true)
  viewCount      Int       @default(0)
  likeCount      Int       @default(0)
  status         String    @default("published") // draft, published, scheduled
  publishDate    DateTime?

  @@index([slug])
  @@index([category])
  @@index([published])
  @@index([createdAt])
  @@index([status])
  @@index([featuredPost])
  @@index([trending])
}
